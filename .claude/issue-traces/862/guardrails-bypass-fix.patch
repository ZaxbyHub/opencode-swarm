+	`${BASH_PATH_BOUNDARY}\\.swarm/evidence/${STRICT_TASK_ID_PATTERN.source.slice(1, -1)}\\.json\\b`,
+);
+
+// Matches any mention of the `.swarm/evidence` path (either the directory
+// itself or any child). Used as the quick filter and for `find -delete`-style
+// checks where the per-task filename is hidden behind `-name`.
+const EVIDENCE_DIR_BASH_RE = new RegExp(
+	`${BASH_PATH_BOUNDARY}\\.swarm/evidence(?:/|$|[\\s'"\`)\\]}])`,
+);
+
+// Matches the `.swarm/evidence` directory EXACTLY (NOT as a parent of some
+// child path). Used for directory-level mutation blocks where targeting the
+// dir itself (`mv .swarm/evidence /tmp/x`, `rm -rf .swarm/evidence`) wipes
+// all per-task files in one stroke, but operating on a child (e.g.
+// `.swarm/evidence/retro-3/...` — phase-scoped subdir) remains permitted by
+// the universal guard.
+const EVIDENCE_DIR_EXACT_BASH_RE = new RegExp(
+	`${BASH_PATH_BOUNDARY}\\.swarm/evidence(?=$|[\\s'"\`)\\]}])`,
+);
